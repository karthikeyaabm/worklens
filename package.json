{
  "name": "worklens",
  "version": "1.0.7",
  "description": "WorkLens | Employee Timelog & Activity Tracking",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "release": "electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.worklens.desktop",
    "productName": "WorkLens",
    "icon": "assets/icon.png",
    "files": [
      "**/*"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "karthikeyaabm",
      "repo": "worklens",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "dotenv": "^16.4.5",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9"
  }
}